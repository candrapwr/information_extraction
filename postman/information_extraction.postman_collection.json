{
  "info": {
    "name": "Local GGUF OCR API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Single-endpoint OCR API using the local GGUF model."
  },
  "item": [
    {
      "name": "Extract Document",
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "formdata",
          "formdata": [
            {
              "key": "file",
              "type": "file",
              "src": ""
            },
            {
              "key": "template",
              "type": "text",
              "value": "ktp"
            }
          ]
        },
        "url": {
          "raw": "{{base_url}}/extract",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "extract"
          ]
        }
      },
      "response": []
    }
  ],
  "event": [],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000"
    }
  ]
}
